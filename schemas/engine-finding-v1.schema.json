{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akvaryum.local/schemas/engine-finding-v1.schema.json",
  "title": "AKVARYUM Engine Finding v1",
  "type": "object",
  "required": [
    "ruleId",
    "severity",
    "title",
    "desc",
    "reason",
    "impact",
    "resolution",
    "subjects",
    "evidence"
  ],
  "properties": {
    "ruleId": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]+$"
    },
    "severity": {
      "enum": ["critical", "warning", "info"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "desc": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "impact": {
      "type": "string",
      "minLength": 1
    },
    "resolution": {
      "type": "string",
      "minLength": 1
    },
    "subjects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
