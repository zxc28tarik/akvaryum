{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zxc28tarik.github.io/akvaryum/schemas/predator-prey-profile-v1.schema.json",
  "title": "AKVARYUM Predator Prey Profile v1",
  "type": "array",
  "items": { "$ref": "#/$defs/profile" },
  "$defs": {
    "slugId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "sourceIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/slugId" }
    },
    "speciesIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/slugId" }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "confidence", "notes"],
      "properties": {
        "status": { "enum": ["reviewed", "verified"] },
        "confidence": { "enum": ["medium", "high"] },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "predatorId",
        "mouthWidthCm",
        "maxSwallowablePreyLengthCm",
        "safeSpeciesIds",
        "riskySpeciesIds",
        "sourceIds",
        "verification"
      ],
      "properties": {
        "predatorId": { "$ref": "#/$defs/slugId" },
        "mouthWidthCm": { "type": "number", "exclusiveMinimum": 0 },
        "maxSwallowablePreyLengthCm": { "type": "number", "exclusiveMinimum": 0 },
        "safeSpeciesIds": { "$ref": "#/$defs/speciesIds" },
        "riskySpeciesIds": { "$ref": "#/$defs/speciesIds" },
        "sourceIds": { "$ref": "#/$defs/sourceIds" },
        "verification": { "$ref": "#/$defs/verification" }
      }
    }
  }
}
