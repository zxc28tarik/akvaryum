{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zxc28tarik.github.io/akvaryum/schemas/source-provenance.schema.json",
  "title": "AKVARYUM kaynak ve doğrulama şeması",
  "type": "object",
  "required": ["catalogVersion", "updatedAt", "sources", "records"],
  "additionalProperties": false,
  "properties": {
    "catalogVersion": { "type": "integer", "minimum": 1 },
    "updatedAt": { "$ref": "#/$defs/date" },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
    "records": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/recordProvenance" } }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "sourceIdList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/slug" }
    },
    "source": {
      "type": "object",
      "required": ["id", "title", "publisher", "accessedAt", "fields", "sourceType", "status", "confidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "title": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "accessedAt": { "$ref": "#/$defs/date" },
        "lastCheckedAt": { "$ref": "#/$defs/date" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "sourceType": {
          "enum": ["primary", "institutional", "book", "expert", "retailer", "community", "internal_legacy", "derived"]
        },
        "status": { "enum": ["unverified", "reviewed", "verified", "deprecated"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "note": { "type": "string" }
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "confidence"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["needs_review", "reviewed", "verified", "deprecated"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "lastReviewedAt": { "$ref": "#/$defs/date" },
        "notes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "recordProvenance": {
      "type": "object",
      "required": ["id", "collection", "sourceIds", "fieldSourceIds", "verification"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "collection": { "enum": ["fish", "plants", "substrates", "tankPresets"] },
        "sourceIds": { "$ref": "#/$defs/sourceIdList" },
        "fieldSourceIds": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "pattern": "^[a-z][a-zA-Z0-9_.-]*$" },
          "additionalProperties": { "$ref": "#/$defs/sourceIdList" }
        },
        "verification": { "$ref": "#/$defs/verification" }
      }
    }
  }
}
