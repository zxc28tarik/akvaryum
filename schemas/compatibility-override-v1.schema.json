{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akvaryum.local/schemas/compatibility-override-v1.schema.json",
  "title": "AKVARYUM Compatibility Override v1",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/compatibilityOverride"
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "localizedText": {
      "type": "object",
      "required": ["tr", "en"],
      "additionalProperties": false,
      "properties": {
        "tr": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "confidence"],
      "additionalProperties": false,
      "properties": {
        "status": { "const": "verified" },
        "confidence": { "enum": ["medium", "high"] }
      }
    },
    "compatibilityOverride": {
      "type": "object",
      "required": [
        "id",
        "a",
        "b",
        "direction",
        "status",
        "reasons",
        "conditions",
        "impact",
        "resolution",
        "sourceIds",
        "verifiedAt",
        "verification"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "a": { "$ref": "#/$defs/slug" },
        "b": { "$ref": "#/$defs/slug" },
        "direction": { "enum": ["both", "a_to_b", "b_to_a"] },
        "status": { "enum": ["compatible", "caution", "incompatible", "conditional"] },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "impact": { "$ref": "#/$defs/localizedText" },
        "resolution": { "$ref": "#/$defs/localizedText" },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/slug" }
        },
        "verifiedAt": { "$ref": "#/$defs/date" },
        "verification": { "$ref": "#/$defs/verification" }
      }
    }
  }
}
